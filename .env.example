# ─────────────────────────────────────────────────────────────────────────────
# Market Basket Analytics — Variables de entorno
# Copia este archivo como .env y completa los valores para desarrollo local.
# En Cloud Run, estas variables se configuran en el despliegue (--set-env-vars).
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# Nombre del bucket GCS donde se almacenan los datos raw y procesados.
# Si no se define, la app lee desde data/processed/ local (modo desarrollo).
GCS_BUCKET=market-basket-data

# ── Google Cloud Project ──────────────────────────────────────────────────────
# ID del proyecto GCloud. Requerido para lanzar el Cloud Run Job desde la API.
GOOGLE_CLOUD_PROJECT=my-gcloud-project-id

# ── Cloud Run Job (ETL) ───────────────────────────────────────────────────────
# Nombre del Cloud Run Job que ejecuta el ETL incremental.
ETL_JOB_NAME=market-basket-etl

# Región donde está desplegado el Cloud Run Job.
CLOUD_RUN_REGION=us-central1

# ── FastAPI → Streamlit ───────────────────────────────────────────────────────
# URL base de la FastAPI. El dashboard Streamlit la usa para todas sus consultas.
# En Cloud Run, reemplazar con la URL del servicio FastAPI desplegado.
API_URL=http://localhost:8000
