# Cloud Run Job — ETL incremental
# Ejecuta src/etl/precompute.py y termina.
# Se activa bajo demanda (nunca está "corriendo" cuando no hay trabajo).

FROM python:3.13-slim
RUN apt-get update && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY src/ ./src/
# Punto de entrada: ETL incremental
CMD ["python", "-m", "src.etl.precompute"]
